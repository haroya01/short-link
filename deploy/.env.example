# Hosts
BACKEND_HOST=kurl.me
FRONTEND_HOST=app.kurl.me
TZ=Asia/Seoul

# MySQL
MYSQL_DATABASE=short_link
MYSQL_USER=short_link
MYSQL_PASSWORD=replace-me-strong
MYSQL_ROOT_PASSWORD=replace-me-strong-root

# Redis
REDIS_PASSWORD=replace-me-strong

# JWT keypair — generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Copy the body (between BEGIN/END lines) onto a single line for each var.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Google OAuth — Cloud Console → OAuth client ID (Web app)
# Authorized redirect URI: https://kurl.me/login/oauth2/code/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 2FA secret encryption — 32 bytes base64. Generate with:
#   openssl rand -base64 32
TWOFA_AES_KEY=

# Optional — if you have a MaxMind license, fresh GeoLite2-City + ASN dbs are
# downloaded at build time. Without it the bundled fallback (city only) is used.
MAXMIND_LICENSE_KEY=

# PoW
POW_ENFORCE=true
POW_DIFFICULTY=3

# Per-user shortener quota
LINK_QUOTA_AUTHENTICATED=200

# Avatar upload (S3 presigned PUT). Bucket / IAM / CORS 셋업은 README 참조.
# 비워두면 avatar endpoint 가 503 — 앱 나머지는 정상.
AVATAR_S3_BUCKET=
AVATAR_S3_REGION=ap-northeast-2
# CDN 안 끼우면 비워둠 (자동으로 raw S3 virtual-host URL 사용).
AVATAR_S3_PUBLIC_BASE_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
